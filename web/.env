# ============================================================
# BannerPrint — .env
# Скопировать на VPS: /home/bannerpdf/banner_web/.env
# SELFWORK_SHOP_ID и SELFWORK_API_KEY — заглушки до регистрации
# ============================================================

# Платёжный провайдер Сам.Эквайринг
SELFWORK_SHOP_ID=PLACEHOLDER_SHOP_ID
SELFWORK_API_KEY=PLACEHOLDER_API_KEY

# Сайт
SITE_BASE_URL=https://bannerbot.ru
SITE_PDF_PRICE=299
ALLOWED_ORIGINS=https://bannerbot.ru

# БД
WEB_DB_PATH=/app/data/banner_web.db

# Пути к ресурсам
FONTS_DIR=/app/fonts
ICC_PROFILE_PATH=/profiles/ISOcoated_v2_300_eci.icc
TEMPLATES_PATH=/app/templates.json
BATCH_DIR=/tmp/bannerprint_batches

# Авторизация
ADMIN_TOKEN=42985733102f0672409c942f33b1d89a48ad27a751acf596114b0509a5326fbf
BOT_INTERNAL_SECRET=16db17376577e11cce6ff560532a316c

# Uvicorn — строго 1 worker (SQLite без внешней синхронизации)
UVICORN_WORKERS=1
